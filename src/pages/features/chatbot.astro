---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="GovChat AI Chatbot — Viv KM"
  description="A municipal AI chatbot that only answers from knowledge your staff has approved. No hallucinations. No surprises. Residents get accurate answers 24/7."
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="relative bg-ink min-h-[90vh] flex items-center overflow-hidden pt-16">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-10 right-0 w-[800px] h-[600px] bg-brand/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 -left-20 w-[500px] h-[400px] bg-blue-900/20 rounded-full blur-3xl"></div>
      <div class="absolute inset-0" style="background-image:radial-gradient(rgba(255,255,255,.04) 1px,transparent 1px);background-size:28px 28px"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 py-24 grid lg:grid-cols-5 gap-12 items-center">
      <div class="lg:col-span-3">
        <div class="inline-flex items-center gap-2 bg-brand/10 border border-brand/20 rounded-full px-4 py-1.5 mb-7">
          <div class="w-5 h-5 rounded-full bg-brand/20 flex items-center justify-center">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#146FF8" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <span class="text-xs font-semibold text-brand">GovChat AI Chatbot</span>
        </div>

        <h1 class="text-4xl lg:text-[52px] font-black text-white leading-[1.06] tracking-tight mb-6">
          Only answer it once.
        </h1>

        <p class="text-xl text-gray-300 leading-relaxed mb-4 max-w-lg">
          Your staff answers every common question — once. GovChat answers the rest, forever, for every resident who asks.
        </p>
        <p class="text-gray-400 leading-relaxed mb-10 max-w-lg">
          No hallucinations. No making things up. Every response comes word-for-word from a knowledge base article your team wrote, reviewed, and approved. If the answer isn't in the KB, GovChat says so and offers to connect the resident with staff.
        </p>

        <div class="flex flex-wrap gap-3 mb-12">
          <a href="mailto:kalman@vivwebsolutions.com?subject=GovChat Demo Request"
             class="inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white font-semibold px-6 py-3.5 rounded-xl transition-colors text-sm shadow-lg shadow-brand/25">
            Get a Live Demo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#how-it-works"
             class="inline-flex items-center gap-2 bg-white/8 border border-white/12 text-white font-semibold px-6 py-3.5 rounded-xl transition-colors text-sm hover:bg-white/14">
            See how it works
          </a>
        </div>

        <div class="grid grid-cols-3 gap-4 max-w-md">
          {[
            { n: '2s', label: 'avg. response time' },
            { n: '87%', label: 'inquiries resolved without staff' },
            { n: '24/7', label: 'always available' },
          ].map(s => (
            <div class="text-center bg-white/5 border border-white/10 rounded-xl p-3">
              <div class="text-xl font-black text-white">{s.n}</div>
              <div class="text-[10px] text-gray-400 mt-0.5">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Chat preview -->
      <div class="lg:col-span-2 hidden lg:block">
        <div class="bg-[#0d1d35] border border-white/12 rounded-2xl overflow-hidden shadow-2xl shadow-black/40">
          <div class="flex items-center justify-between px-4 py-3 border-b border-white/8 bg-white/3">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-full bg-brand flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              </div>
              <div>
                <div class="text-[12px] font-semibold text-white">City Hall Assistant</div>
                <div class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span><span class="text-[10px] text-emerald-400">Online — 24/7</span></div>
              </div>
            </div>
            <div class="text-[10px] text-gray-500 bg-white/5 px-2 py-1 rounded">Powered by Viv KM</div>
          </div>

          <div class="p-4 space-y-3">
            <!-- Bot greeting -->
            <div class="flex gap-2">
              <div class="w-6 h-6 rounded-full bg-brand/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#146FF8" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              </div>
              <div class="bg-white/7 border border-white/8 rounded-2xl rounded-tl-sm px-3 py-2.5 text-[11px] text-gray-300 leading-relaxed max-w-[80%]">
                Hi! I'm the City Hall AI assistant. I can answer questions about permits, taxes, parking, public works, and more. What do you need?
              </div>
            </div>
            <!-- User -->
            <div class="flex justify-end">
              <div class="bg-brand/20 border border-brand/30 rounded-2xl rounded-tr-sm px-3 py-2.5 text-[11px] text-gray-100">
                How do I get a building permit for a deck?
              </div>
            </div>
            <!-- Bot answer -->
            <div class="flex gap-2">
              <div class="w-6 h-6 rounded-full bg-brand/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#146FF8" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              </div>
              <div class="bg-white/7 border border-white/8 rounded-2xl rounded-tl-sm px-3 py-2.5 text-[11px] text-gray-300 leading-relaxed max-w-[85%]">
                For a residential deck you'll need a <strong class="text-white">Building Permit</strong> from our Inspectional Services Division. Here's the process:<br/><br/>
                1. Submit plans online at <span class="text-brand">city.gov/permits</span><br/>
                2. Pay the fee: <strong class="text-white">$75 base + $6/100 sq ft</strong><br/>
                3. Typical review: <strong class="text-white">5–7 business days</strong><br/><br/>
                📋 You'll need to include a site plan showing setbacks from property lines. Is your deck attached or freestanding?
              </div>
            </div>
            <!-- User -->
            <div class="flex justify-end">
              <div class="bg-brand/20 border border-brand/30 rounded-2xl rounded-tr-sm px-3 py-2.5 text-[11px] text-gray-100">
                It's attached to the house
              </div>
            </div>
            <!-- Bot -->
            <div class="flex gap-2">
              <div class="w-6 h-6 rounded-full bg-brand/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#146FF8" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              </div>
              <div class="bg-white/7 border border-white/8 rounded-2xl rounded-tl-sm px-3 py-2.5 text-[11px] text-gray-300 leading-relaxed max-w-[85%]">
                Attached decks also need a <strong class="text-white">ledger attachment detail</strong> showing how it connects to the house structure. The plan checker will confirm this is waterproofed correctly.<br/><br/>
                One inspector handles your whole process — from plan review to final inspection. Ready to start your application?
              </div>
            </div>
          </div>

          <div class="px-4 pb-4">
            <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-xl px-3 py-2">
              <span class="text-[10px] text-gray-500 flex-1">Ask about permits, taxes, trash, parking…</span>
              <div class="w-5 h-5 bg-brand rounded-lg flex items-center justify-center shrink-0 cursor-default">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE CORE DIFFERENCE ═══ -->
  <section class="bg-white py-20 border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="text-xs font-semibold text-brand uppercase tracking-widest mb-4">The GovChat Difference</div>
      <h2 class="text-3xl font-black text-gray-900 mb-6">Built for governments. Not for startups.</h2>
      <p class="text-gray-500 leading-relaxed max-w-2xl mx-auto mb-14">
        Generic AI chatbots make things up. That's fine for a music recommendation. It's not fine when a resident relies on your chatbot for a permit fee, a tax deadline, or a health clinic location.
        GovChat never invents information — it only responds from articles your staff approved.
      </p>
      <div class="grid md:grid-cols-2 gap-5 text-left">
        <div class="bg-red-50 border border-red-100 rounded-2xl p-6">
          <div class="text-sm font-bold text-red-700 mb-4 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Generic AI Chatbot
          </div>
          <ul class="space-y-3 text-sm text-red-800/80">
            {[
              'Generates answers from training data — may be outdated or wrong',
              'No connection to your actual ordinances, schedules, or policies',
              "Can't know your current fee schedule or hours of operation",
              'Confident-sounding wrong answers erode public trust',
              'No audit trail — who approved this answer?',
            ].map(t => (
              <li class="flex items-start gap-2.5">
                <svg class="shrink-0 mt-0.5 text-red-400" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                {t}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-6">
          <div class="text-sm font-bold text-emerald-700 mb-4 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            GovChat
          </div>
          <ul class="space-y-3 text-sm text-emerald-800/80">
            {[
              'Only responds from articles your staff wrote and approved',
              'Knowledge base is always current — you update one article, all answers update',
              "When it doesn't know, it says so — and routes to the right staff contact",
              'Full audit trail: every answer traces back to a specific KB article',
              "PII redacted, legal flags blocked — won't surface information that shouldn't be public",
            ].map(t => (
              <li class="flex items-start gap-2.5">
                <svg class="shrink-0 mt-0.5 text-emerald-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {t}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section id="how-it-works" class="bg-slate-50 border-y border-gray-100 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <div class="text-xs font-semibold text-brand uppercase tracking-widest mb-3">How It Works</div>
        <h2 class="text-3xl font-black text-gray-900">Answer once. Let GovChat answer forever.</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-5 relative">
        {[
          { n: '01', icon: '💬', title: 'Resident asks a question', body: 'Via the chatbot widget on your website, any page, any time. No app to download.' },
          { n: '02', icon: '📚', title: 'GovChat searches the KB', body: 'Semantic search finds the most relevant approved answer. No making things up.' },
          { n: '03', icon: '✅', title: 'Approved answer delivered', body: 'The response comes from an article your staff reviewed. Accurate. Attributable. Current.' },
          { n: '04', icon: '🔁', title: 'New questions become articles', body: 'Unanswered questions go into the KB pipeline for staff to draft, review, and approve.' },
        ].map(s => (
          <div class="bg-white rounded-2xl border border-gray-100 p-5 relative">
            <div class="text-[10px] font-black text-gray-300 mb-3">{s.n}</div>
            <div class="text-2xl mb-3">{s.icon}</div>
            <h3 class="font-bold text-gray-900 text-sm mb-2">{s.title}</h3>
            <p class="text-xs text-gray-500 leading-relaxed">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FEATURES GRID ═══ -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <div class="text-xs font-semibold text-brand uppercase tracking-widest mb-3">Features</div>
        <h2 class="text-3xl font-black text-gray-900">Everything your chatbot needs. Nothing it doesn't.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: '🛡️', title: 'KB-only responses', body: "GovChat never generates a response outside your knowledge base. If the answer isn't approved, it acknowledges it doesn't know and offers a staff contact." },
          { icon: '🌐', title: 'Embeds on your existing site', body: 'A simple JavaScript snippet drops the chatbot onto your WordPress, Drupal, or any CMS. No site migration required.' },
          { icon: '🔄', title: 'Always-current answers', body: 'When you update a KB article — new fee, new hours, new policy — the chatbot reflects it immediately. No re-training, no delay.' },
          { icon: '📞', title: 'Human handoff', body: "When a question can't be answered, GovChat routes to the right department contact — email, phone, or 311 intake — with context included." },
          { icon: '📊', title: 'Conversation analytics', body: "See what residents are asking, what's being answered automatically vs. escalated, and which topics need new KB articles." },
          { icon: '🎨', title: 'Branded appearance', body: "Customize the chatbot's colors, avatar, greeting, and name to match your city's identity. Residents see your city, not ours." },
          { icon: '🔒', title: 'PII protection', body: 'Account numbers, SSNs, and personal health information are automatically redacted before any message is logged or stored.' },
          { icon: '⚖️', title: 'Legal & liability guards', body: 'Legal advice, litigation-adjacent questions, and ADA complaint intake are automatically blocked from the chatbot and routed to staff.' },
          { icon: '🌎', title: 'Multi-language ready', body: 'GovChat supports Spanish, Haitian Creole, Portuguese, and more — serving diverse communities in their language without extra setup.' },
        ].map(f => (
          <div class="flex items-start gap-4 p-5 rounded-xl border border-gray-100 hover:border-brand/30 hover:shadow-sm transition-all">
            <div class="text-xl shrink-0">{f.icon}</div>
            <div>
              <h3 class="font-semibold text-gray-900 text-sm mb-1">{f.title}</h3>
              <p class="text-xs text-gray-500 leading-relaxed">{f.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ DEPARTMENTS ═══ -->
  <section class="bg-ink py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="text-xs font-semibold text-brand uppercase tracking-widest mb-3">By Department</div>
        <h2 class="text-3xl font-black text-white mb-4">One chatbot. Every department.</h2>
        <p class="text-gray-400">GovChat handles questions for every city department from a single knowledge base. Each department manages its own section.</p>
      </div>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
        {[
          { icon: '🗳️', dept: 'Elections', qs: ['Am I registered to vote?', 'Where is my polling place?', 'How do I get an absentee ballot?'] },
          { icon: '🏗️', dept: 'Building & Permits', qs: ['What permits do I need for a deck?', 'How long does plan review take?', 'What is the fee for a fence permit?'] },
          { icon: '💧', dept: 'Public Works', qs: ['When is my street cleaned?', 'How do I report a pothole?', 'When is bulk pickup in my area?'] },
          { icon: '💰', dept: 'Finance & Taxes', qs: ['When are property taxes due?', 'How do I apply for a tax exemption?', 'Where do I pay a parking ticket?'] },
          { icon: '🌳', dept: 'Parks & Recreation', qs: ['How do I reserve a pavilion?', 'What summer camps are available?', 'Can I bring my dog to the park?'] },
          { icon: '📋', dept: 'City Clerk', qs: ['How do I get a marriage license?', 'Where can I get a birth certificate?', 'When does the city council meet?'] },
        ].map(d => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/8 transition-colors">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xl">{d.icon}</span>
              <span class="font-semibold text-white text-sm">{d.dept}</span>
            </div>
            <ul class="space-y-1.5">
              {d.qs.map(q => (
                <li class="text-[11px] text-gray-400 flex items-start gap-1.5">
                  <svg class="shrink-0 mt-0.5 text-gray-600" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {q}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="bg-gradient-to-br from-brand-dark via-brand to-blue-500 py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-black text-white mb-4">See GovChat on your actual website.</h2>
      <p class="text-blue-100 mb-10 max-w-lg mx-auto">
        We'll install GovChat on your city's WordPress site for a live demo — your real content, your real questions, so your team can see it working before they commit to anything.
      </p>
      <a href="mailto:kalman@vivwebsolutions.com?subject=GovChat Demo Request"
         class="inline-flex items-center gap-2 bg-white text-brand font-bold px-8 py-4 rounded-xl hover:bg-blue-50 transition-colors shadow-xl shadow-black/20 text-sm">
        Request a Live Demo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
