<script>
  function activateTab(id: string) {
    document.querySelectorAll('.demo-tab').forEach(t => {
      t.classList.remove('bg-brand', 'text-white');
      t.classList.add('bg-white', 'border', 'border-gray-200', 'text-gray-600');
    });
    const activeBtn = document.querySelector(`.demo-tab[data-demo="${id}"]`) as HTMLElement;
    if (activeBtn) {
      activeBtn.classList.add('bg-brand', 'text-white');
      activeBtn.classList.remove('bg-white', 'border', 'border-gray-200', 'text-gray-600');
    }
    document.querySelectorAll('.demo-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById(`demo-${id}`)?.classList.remove('hidden');
  }

  document.querySelectorAll('.demo-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.demo!;
      activateTab(id);
      history.replaceState(null, '', `#${id}`);
    });
  });

  // Activate tab from URL hash on load
  const hash = location.hash.replace('#', '');
  if (hash && document.querySelector(`.demo-tab[data-demo="${hash}"]`)) {
    activateTab(hash);
    document.getElementById('demo-tabs')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
