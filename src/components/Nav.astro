---
const { current = '' } = Astro.props;

const products = [
  { label: 'GovChat AI Chatbot', sub: 'AI-powered resident Q&A, 24/7', href: '/features/chatbot', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', color: 'bg-brand/15 text-brand', soon: false },
  { label: 'Knowledge Management', sub: 'Editorial pipeline for public answers', href: '/features/knowledge-management', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', color: 'bg-violet-500/15 text-violet-400', soon: false },
  { label: 'Website Intelligence', sub: 'Gap detection & content improvement', href: '#', icon: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'bg-amber-500/15 text-amber-400', soon: true },
  { label: 'CRM & Ticketing', sub: 'In-house or integrated case management', href: '#', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', color: 'bg-emerald-500/15 text-emerald-400', soon: true },
];

const departments = [
  { label: 'Elections', sub: 'Voter registration, ballots, FAQs', href: '/departments/elections', icon: '🗳️', soon: false },
  { label: 'Building & Permits', sub: 'Permit status, inspection scheduling', href: '#', icon: '🏗️', soon: true },
  { label: 'Public Works', sub: 'Service requests, 311 routing', href: '#', icon: '🚰', soon: true },
  { label: 'Parks & Recreation', sub: 'Programs, reservations, hours', href: '#', icon: '🌳', soon: true },
  { label: 'Finance & Taxes', sub: 'Payments, assessments, deadlines', href: '#', icon: '💰', soon: true },
  { label: 'City Clerk', sub: 'Records, licensing, council info', href: '#', icon: '📋', soon: true },
];

const forOrgs = [
  { label: 'Small Cities & Towns', sub: 'Under 75,000 residents', href: '#', soon: true },
  { label: 'Counties', sub: 'Multi-department county governments', href: '#', soon: true },
  { label: 'Municipalities', sub: 'Full municipal deployment', href: '#', soon: true },
  { label: 'Single Department', sub: 'Start with one team, expand later', href: '#', soon: true },
];
---

<header class="fixed top-0 inset-x-0 z-50 border-b border-white/8 bg-ink/92 backdrop-blur-md" id="site-header">
  <nav class="max-w-7xl mx-auto px-5 h-16 flex items-center gap-1">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 mr-5 shrink-0" aria-label="Viv Knowledge Management">
      <svg class="h-9 w-auto shrink-0" viewBox="0 0 296.17 246.35" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <mask id="viv-nav-spinner-mask" maskUnits="userSpaceOnUse" x="0" y="0" width="296.17" height="246.35">
            <path d="M172.72,126.13 C172.72,116.60 162.28,111.29 152.35,111.29 C142.42,111.29 131.98,116.60 131.98,126.13 H0 V0.00 H296.17 V126.13 H172.72 Z" fill="#ffffff" fill-rule="evenodd"/>
          </mask>
        </defs>
        <!-- Spinner star (gold, clipped to top area above letters) -->
        <g mask="url(#viv-nav-spinner-mask)">
          <polygon fill="#d6d351" fill-rule="evenodd" points="153.07,19.98 160.80,102.20 215.38,40.22 173.30,111.29 253.88,93.22 178.07,125.98 253.88,158.74 173.30,140.67 215.38,211.74 160.80,149.76 153.07,231.98 145.34,149.76 90.76,211.74 132.84,140.67 52.26,158.74 128.07,125.98 52.26,93.22 132.84,111.29 90.76,40.22 145.34,102.20" />
        </g>
        <!-- Left V -->
        <polygon fill="white" fill-rule="evenodd" points="127.62,138.35 96.98,138.35 73.37,197.96 49.75,138.35 19.11,138.35 16.95,141.41 61.24,246.35 73.37,246.35 85.5,246.35 129.79,141.41 127.62,138.35" />
        <!-- Right V -->
        <polygon fill="white" fill-rule="evenodd" points="286.43,138.35 255.79,138.35 232.18,197.96 208.56,138.35 177.92,138.35 175.76,141.41 220.05,246.35 232.18,246.35 244.3,246.35 288.6,141.41 286.43,138.35" />
        <!-- Center I bar -->
        <polygon fill="white" fill-rule="evenodd" points="137.58,244.05 139.75,246.35 152.39,246.35 152.01,246.35 164.65,246.35 166.81,244.05 166.81,173.71 164.65,171.41 152.01,171.41 152.39,171.41 139.75,171.41 137.58,173.71 137.58,244.05" />
        <!-- I dot -->
        <circle fill="white" r="16.12" transform="translate(152.35 146.85)" />
      </svg>
      <span class="w-px h-4 bg-white/20 shrink-0"></span>
      <span class="font-medium text-gray-400 text-[12px] tracking-tight leading-tight hidden sm:block">Knowledge<br/>Management</span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-0.5 flex-1">

      <!-- Products -->
      <div class="relative nav-group">
        <button class="nav-trigger flex items-center gap-1 px-3.5 py-2 text-[13px] font-medium text-gray-300 hover:text-white rounded-lg hover:bg-white/8 transition-colors" data-target="dd-products">
          Products
          <svg class="nav-chevron transition-transform duration-150" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="dd-products" class="nav-dropdown hidden absolute top-full left-0 mt-2 w-[320px] bg-[#0d1d35] border border-white/10 rounded-2xl shadow-2xl shadow-black/40 p-2.5 z-50">
          {products.map(p => p.soon ? (
            <div class="flex items-start gap-3 p-2.5 rounded-xl opacity-40 cursor-not-allowed select-none">
              <div class:list={["w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5", p.color]}>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d={p.icon}/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-[13px] font-semibold text-white flex items-center gap-2">{p.label} <span class="text-[9px] font-bold bg-white/10 text-gray-400 px-1.5 py-0.5 rounded-full tracking-wide">SOON</span></div>
                <div class="text-[11px] text-gray-500 mt-0.5">{p.sub}</div>
              </div>
            </div>
          ) : (
            <a href={p.href} class="flex items-start gap-3 p-2.5 rounded-xl hover:bg-white/6 transition-colors group">
              <div class:list={["w-8 h-8 rounded-lg flex items-center justify-center shrink-0 mt-0.5", p.color]}>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d={p.icon}/></svg>
              </div>
              <div>
                <div class="text-[13px] font-semibold text-white group-hover:text-brand transition-colors">{p.label}</div>
                <div class="text-[11px] text-gray-400 mt-0.5">{p.sub}</div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Departments -->
      <div class="relative nav-group">
        <button class="nav-trigger flex items-center gap-1 px-3.5 py-2 text-[13px] font-medium text-gray-300 hover:text-white rounded-lg hover:bg-white/8 transition-colors" data-target="dd-depts">
          Departments
          <svg class="nav-chevron transition-transform duration-150" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="dd-depts" class="nav-dropdown hidden absolute top-full left-0 mt-2 w-[280px] bg-[#0d1d35] border border-white/10 rounded-2xl shadow-2xl shadow-black/40 p-2.5 z-50">
          {departments.map(d => d.soon ? (
            <div class="flex items-center gap-3 px-3 py-2 rounded-xl opacity-40 cursor-not-allowed select-none">
              <span class="text-base leading-none">{d.icon}</span>
              <div class="flex-1">
                <div class="text-[13px] font-medium text-white flex items-center gap-2">{d.label} <span class="text-[9px] font-bold bg-white/10 text-gray-400 px-1.5 py-0.5 rounded-full">SOON</span></div>
                <div class="text-[11px] text-gray-500">{d.sub}</div>
              </div>
            </div>
          ) : (
            <a href={d.href} class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/6 transition-colors group">
              <span class="text-base leading-none">{d.icon}</span>
              <div>
                <div class="text-[13px] font-semibold text-white group-hover:text-brand transition-colors">{d.label}</div>
                <div class="text-[11px] text-gray-400">{d.sub}</div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- For -->
      <div class="relative nav-group">
        <button class="nav-trigger flex items-center gap-1 px-3.5 py-2 text-[13px] font-medium text-gray-300 hover:text-white rounded-lg hover:bg-white/8 transition-colors" data-target="dd-for">
          For
          <svg class="nav-chevron transition-transform duration-150" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="dd-for" class="nav-dropdown hidden absolute top-full left-0 mt-2 w-[240px] bg-[#0d1d35] border border-white/10 rounded-2xl shadow-2xl shadow-black/40 p-2.5 z-50">
          {forOrgs.map(o => (
            <div class="flex flex-col px-3 py-2 rounded-xl opacity-40 cursor-not-allowed select-none">
              <div class="text-[13px] font-medium text-white flex items-center gap-2">{o.label} <span class="text-[9px] font-bold bg-white/10 text-gray-400 px-1.5 py-0.5 rounded-full">SOON</span></div>
              <div class="text-[11px] text-gray-500">{o.sub}</div>
            </div>
          ))}
        </div>
      </div>

      <a href="/integrations" class:list={["px-3.5 py-2 text-[13px] font-medium rounded-lg transition-colors", current === 'integrations' ? 'text-white bg-white/8' : 'text-gray-300 hover:text-white hover:bg-white/8']}>Integrations</a>
      <a href="/pricing" class:list={["px-3.5 py-2 text-[13px] font-medium rounded-lg transition-colors", current === 'pricing' ? 'text-white bg-white/8' : 'text-gray-300 hover:text-white hover:bg-white/8']}>Pricing</a>
    </div>

    <!-- CTA -->
    <a href="mailto:kalman@vivwebsolutions.com?subject=Viv KM Demo Request"
       class="ml-auto flex items-center gap-1.5 bg-brand hover:bg-brand-dark text-white text-[13px] font-semibold px-4 py-2 rounded-lg transition-colors shadow-md shadow-brand/20 shrink-0">
      Book a Demo
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="lg:hidden ml-3 p-2 text-gray-300 hover:text-white rounded-lg hover:bg-white/8 transition-colors" aria-label="Menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/8 bg-ink/98 px-5 py-4 space-y-1">
    <a href="/features/chatbot" class="block px-3 py-2 text-sm text-gray-300 hover:text-white rounded-lg hover:bg-white/8">GovChat AI Chatbot</a>
    <a href="/features/knowledge-management" class="block px-3 py-2 text-sm text-gray-300 hover:text-white rounded-lg hover:bg-white/8">Knowledge Management</a>
    <a href="/departments/elections" class="block px-3 py-2 text-sm text-gray-300 hover:text-white rounded-lg hover:bg-white/8">🗳️ Elections Department</a>
    <a href="/integrations" class="block px-3 py-2 text-sm text-gray-300 hover:text-white rounded-lg hover:bg-white/8">Integrations</a>
    <a href="/pricing" class="block px-3 py-2 text-sm text-gray-300 hover:text-white rounded-lg hover:bg-white/8">Pricing</a>
  </div>
</header>

<script>
  // Dropdown open/close
  const triggers = document.querySelectorAll('.nav-trigger');
  let openId = null;

  function closeAll() {
    document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.add('hidden'));
    document.querySelectorAll('.nav-chevron').forEach(c => c.style.transform = '');
    openId = null;
  }

  triggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = trigger.dataset.target;
      const dd = document.getElementById(id);
      const chevron = trigger.querySelector('.nav-chevron');
      if (openId === id) {
        closeAll();
      } else {
        closeAll();
        dd?.classList.remove('hidden');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
        openId = id;
      }
    });
  });

  // Close when clicking outside
  document.addEventListener('click', closeAll);
  document.querySelectorAll('.nav-dropdown').forEach(d => d.addEventListener('click', e => e.stopPropagation()));

  // Mobile menu
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
