---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Viv KM — Only answer it once.',
  description = 'Viv KM turns every resident inquiry into a growing knowledge base your AI chatbot draws from — reviewed, redacted, and approved by your team before it goes public.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="font-sans antialiased bg-white text-gray-900">
  <slot />
</body>
</html>
